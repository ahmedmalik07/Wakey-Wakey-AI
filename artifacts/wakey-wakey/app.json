{
  "expo": {
    "name": "Wakey Wakey",
    "slug": "wakey-wakey",
    "version": "1.0.0",
    "description": "Wakey Wakey is the alarm that actually gets you out of bed. Choose your wake-up challenge — walk a set number of steps, shake your phone, or solve math problems — and the alarm only stops once you've done it. Pick from soothing built-in sounds or your own music, see a different upbeat morning message every time, and use the Settings tab to dial in haptics, snooze length, default difficulty, and battery-optimization tweaks so alarms reliably fire on Android. No ads inside the wake-up flow, no dark patterns, just a beautifully designed, premium morning routine by wyibe.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wakey-wakey",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1530"
    },
    "ios": {
      "supportsTablet": false,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSMotionUsageDescription": "Wakey Wakey counts your steps to dismiss alarms so you actually wake up.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "package": "com.wyibe.wakeywakey",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1A1530"
      },
      "permissions": [
        "ACTIVITY_RECOGNITION",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "WAKE_LOCK",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "DISABLE_KEYGUARD",
        "FOREGROUND_SERVICE",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "USE_FULL_SCREEN_INTENT",
        "FOREGROUND_SERVICE_SPECIAL_USE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "FOREGROUND_SERVICE_DATA_SYNC"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF7B47",
          "androidMode": "default",
          "androidCollapsedTitle": "Wakey Wakey alarm"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "59eb2ebc-5b14-4e95-9c83-68981f64f330"
      }
    },
    "owner": "ahhmedmalik"
  }
}
